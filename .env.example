# ============================================
# DJAWAL V2 — Variables d'environnement
# Copier ce fichier vers .env.local pour le dev
# Configurer en prod via Vercel dashboard
# ============================================

# === Supabase (CÔTÉ CLIENT — préfixe VITE_) ===
# Récupérer depuis https://app.supabase.com/project/<ref>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Côté serveur uniquement (Edge Functions) — JAMAIS exposer ===
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === LLM APIs (Edge Functions) ===
GEMINI_API_KEY=AIzaSy...
GROQ_API_KEY=gsk_...

# === OAuth Google ===
SUPABASE_AUTH_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
SUPABASE_AUTH_GOOGLE_SECRET=GOCSPX-xxx

# === Emails ===
RESEND_API_KEY=re_...

# === Monitoring (optionnel) ===
VITE_SENTRY_DSN=https://...@sentry.io/...
VITE_UMAMI_WEBSITE_ID=xxx

# === Carte (optionnel, fallback OSM gratuit si vide) ===
VITE_MAPTILER_KEY=
